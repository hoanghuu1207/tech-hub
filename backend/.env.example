# App
APP_NAME=TechShop API
DEBUG=true
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=techshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Note: Sử dụng asyncpg thay vì kết nối psycopg thông thường để phục vụ code async trên toàn app
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/techshop

# Qdrant
QDRANT_CLUSTER_ENDPOINT=your-qdrant-cluster-url
QDRANT_API_KEY=your-qdrant-api-key

# OpenAI
OPENAI_API_KEY=your-openai-key

# PayOs
PAYOS_CLIENT_ID=your-client-id
PAYOS_API_KEY=your-api-key
PAYOS_CHECKSUM_KEY=your-checksum-key
